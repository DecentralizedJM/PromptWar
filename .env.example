# Copy to .env.local for development. Set the same keys in Cloud Run (use Secret Manager for GEMINI_API_KEY).

# ── Google AI (server only — never NEXT_PUBLIC_) ─────────────────────────────
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Firebase Web app (client — safe to expose with NEXT_PUBLIC_) ──────────────
# Firebase Console → Project settings → Your apps → Web app → SDK setup
# If your project is NOT "promptwar", replace every NEXT_PUBLIC_FIREBASE_* value below
# with the exact snippet from your own project.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=promptwar.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=promptwar
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=promptwar.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=214175642765
NEXT_PUBLIC_FIREBASE_APP_ID=1:214175642765:web:8676d4948a39d8995a9758
